{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./resources/js/*"],
            "@/components/*": ["./resources/js/components/*"],
            "@/components/ui/*": ["./resources/js/components/ui/*"],
            "@/lib/*": ["./resources/js/lib/*"]
        },
        "types": ["vite/client"],
        "allowJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "skipLibCheck": true
    },
    "include": [
        "resources/js/**/*.js",
        "resources/js/**/*.jsx",
        "resources/js/**/*.ts",
        "resources/js/**/*.tsx"
    ]
}
